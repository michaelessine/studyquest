// StudyQuest Prisma schema — PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id        String   @id @default(uuid())
  code      String?
  name      String
  subject   String
  semester  String?
  year      Int?
  status    String   @default("active")
  grade     Float?
  xpAwarded Int      @default(0)
  createdAt DateTime @default(now())

  topics     Topic[]
  deadlines  Deadline[]
  sessions   SessionLog[]
  skillNodes SkillNode[]
}

model SkillNode {
  id                 String    @id @default(uuid())
  name               String
  subject            String
  category           String    @default("")
  tier               Int       @default(0)
  status             String    @default("locked")   // locked | unlocked | in_progress | mastered
  masteryLevel       Float     @default(0)           // 0–5 in 0.5 increments
  xpValue            Int       @default(100)
  courseId           String?
  nextReviewAt       DateTime?
  reviewIntervalDays Int       @default(1)
  masteryUpdatedAt   DateTime?

  course           Course?           @relation(fields: [courseId], references: [id])
  prerequisites    SkillDependency[] @relation("Dependent")
  dependents       SkillDependency[] @relation("Prerequisite")
  topics           Topic[]
  quizzes          Quiz[]
  quizResults      QuizResult[]
  conceptMaps      ConceptMap[]
  debateSessions   DebateSession[]
  teachSessions    TeachSession[]
  researchPapers   ResearchPaper[]
  textbookChapters TextbookChapter[]
  socraticSessions SocraticSession[]
  studySessions    StudySession[]
}

model SkillDependency {
  prerequisiteId String
  dependentId    String

  prerequisite SkillNode @relation("Prerequisite", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  dependent    SkillNode @relation("Dependent",    fields: [dependentId],    references: [id], onDelete: Cascade)

  @@id([prerequisiteId, dependentId])
}

model Topic {
  id          String  @id @default(uuid())
  courseId    String
  skillNodeId String?
  title       String
  week        Int     @default(1)
  status      String  @default("pending")
  source      String?

  course    Course     @relation(fields: [courseId], references: [id])
  skillNode SkillNode? @relation(fields: [skillNodeId], references: [id])
}

model Deadline {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  type      String
  dueDate   DateTime
  completed Boolean  @default(false)
  xpValue   Int      @default(100)

  course Course @relation(fields: [courseId], references: [id])
}

model SessionLog {
  id           String   @id @default(uuid())
  courseId     String?
  loggedAt     DateTime @default(now())
  rawNote      String
  durationMins Int      @default(30)
  xpEarned     Int      @default(10)

  course Course? @relation(fields: [courseId], references: [id])
}

model Achievement {
  id         String    @id @default(uuid())
  name       String    @unique
  condition  String
  unlockedAt DateTime?
}

model Quiz {
  id          String   @id @default(uuid())
  skillNodeId String
  topicName   String
  subject     String
  questions   Json
  quizType    String   @default("practice")   // practice | exam
  createdAt   DateTime @default(now())

  skillNode SkillNode   @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
  results   QuizResult[]
}

model QuizResult {
  id          String   @id @default(uuid())
  quizId      String
  skillNodeId String
  score       Float
  passed      Boolean
  answers     Json
  takenAt     DateTime @default(now())

  quiz      Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

// ─── AI learning feature models ───────────────────────────────────────────────

model LearningPath {
  id              String    @id @default(uuid())
  userId          String    @default("default")
  name            String
  subject         String
  goalDescription String
  topics          Json      // ordered array of skillNodeIds
  estimatedHours  Json      // { skillNodeId: hours }
  pinned          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
}

model ConceptMap {
  id          String   @id @default(uuid())
  userId      String   @default("default")
  skillNodeId String
  subject     String   @default("")
  connections Json     // array of { fromNodeId, toNodeId, explanation }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skillNode   SkillNode               @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
  validations ConceptMapValidation[]
}

model ConceptMapValidation {
  id                 String   @id @default(uuid())
  conceptMapId       String
  validConnections   Json     // { connectionKey: boolean }
  missingConnections Json     // array of suggested connections
  feedback           String
  validatedAt        DateTime @default(now())

  conceptMap ConceptMap @relation(fields: [conceptMapId], references: [id], onDelete: Cascade)
}

model DebateSession {
  id          String   @id @default(uuid())
  userId      String   @default("default")
  skillNodeId String
  position    String
  turns       Json     // array of { role, text }
  score       Float?
  verdict     String?
  createdAt   DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

model TeachSession {
  id               String   @id @default(uuid())
  userId           String   @default("default")
  skillNodeId      String
  userExplanation  String
  claudeEvaluation Json     // { clarity, completeness, misconceptions, score }
  feedback         String
  createdAt        DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

model ResearchPaper {
  id          String   @id @default(uuid())
  skillNodeId String
  title       String
  url         String
  authors     String   @default("")
  year        String   @default("")
  summary     String
  source      String   @default("other") // arxiv | scholar | other
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

model TextbookChapter {
  id          String   @id @default(uuid())
  skillNodeId String
  userLevel   Int      // 0-5
  content     String   // markdown
  generatedAt DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)

  @@unique([skillNodeId, userLevel])
}

model SocraticSession {
  id           String   @id @default(uuid())
  userId       String   @default("default")
  skillNodeId  String
  turns        Json     // array of { role, text }
  sessionScore Float?
  createdAt    DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

model StudySession {
  id          String    @id @default(uuid())
  userId      String    @default("default")
  skillNodeId String?
  startTime   DateTime  @default(now())
  endTime     DateTime?
  durationMins Int      @default(0)
  source      String    @default("manual") // manual | auto

  skillNode SkillNode? @relation(fields: [skillNodeId], references: [id], onDelete: SetNull)
}
