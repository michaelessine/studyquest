// StudyQuest Prisma schema — PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id        String   @id @default(uuid())
  code      String?
  name      String
  subject   String
  semester  String?
  year      Int?
  status    String   @default("active")    // active | completed | planned
  grade     Float?
  xpAwarded Int      @default(0)
  createdAt DateTime @default(now())

  topics     Topic[]
  deadlines  Deadline[]
  sessions   SessionLog[]
  skillNodes SkillNode[]
}

model SkillNode {
  id                 String    @id @default(uuid())
  name               String
  subject            String
  category           String    @default("")
  tier               Int       @default(0)
  status             String    @default("locked")  // locked | unlocked | in_progress | mastered
  masteryLevel       Int       @default(0)          // 0 = not started, 1-4 = in_progress, 5 = mastered
  xpValue            Int       @default(100)
  courseId           String?
  nextReviewAt       DateTime?
  reviewIntervalDays Int       @default(1)
  masteryUpdatedAt   DateTime?

  course        Course?           @relation(fields: [courseId], references: [id])
  prerequisites SkillDependency[] @relation("Dependent")
  dependents    SkillDependency[] @relation("Prerequisite")
  topics        Topic[]
}

model SkillDependency {
  prerequisiteId String
  dependentId    String

  prerequisite SkillNode @relation("Prerequisite", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  dependent    SkillNode @relation("Dependent",    fields: [dependentId],    references: [id], onDelete: Cascade)

  @@id([prerequisiteId, dependentId])
}

model Topic {
  id          String  @id @default(uuid())
  courseId    String
  skillNodeId String?
  title       String
  week        Int     @default(1)
  status      String  @default("pending")
  source      String?

  course    Course     @relation(fields: [courseId], references: [id])
  skillNode SkillNode? @relation(fields: [skillNodeId], references: [id])
}

model Deadline {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  type      String
  dueDate   DateTime
  completed Boolean  @default(false)
  xpValue   Int      @default(100)

  course Course @relation(fields: [courseId], references: [id])
}

model SessionLog {
  id           String   @id @default(uuid())
  courseId     String?
  loggedAt     DateTime @default(now())
  rawNote      String
  durationMins Int      @default(30)
  xpEarned     Int      @default(10)

  course Course? @relation(fields: [courseId], references: [id])
}

model Achievement {
  id         String    @id @default(uuid())
  name       String    @unique
  condition  String
  unlockedAt DateTime?
}
