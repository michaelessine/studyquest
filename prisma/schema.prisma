// StudyQuest Prisma schema — PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id        String   @id @default(uuid())
  code      String?
  name      String
  subject   String
  semester  String?
  year      Int?
  status    String   @default("active")
  grade     Float?
  xpAwarded Int      @default(0)
  createdAt DateTime @default(now())

  // Course components → progress bars
  exerciseSetsTotal Int @default(0)
  exerciseSetsDone  Int @default(0)
  quizzesTotal      Int @default(0)
  quizzesDone       Int @default(0)

  topics        Topic[]
  deadlines     Deadline[]
  studySessions StudySession[]
  skillNodes    SkillNode[]
}

model SkillNode {
  id                 String    @id @default(uuid())
  name               String
  subject            String
  category           String    @default("")
  tier               Int       @default(0)
  status             String    @default("locked")   // locked | unlocked | in_progress | mastered
  masteryLevel       Float     @default(0)           // 0–5 in 0.5 increments
  xpValue            Int       @default(100)
  courseId           String?
  nextReviewAt       DateTime?
  reviewIntervalDays Int       @default(1)
  masteryUpdatedAt   DateTime?

  course           Course?           @relation(fields: [courseId], references: [id])
  prerequisites    SkillDependency[] @relation("Dependent")
  dependents       SkillDependency[] @relation("Prerequisite")
  topics           Topic[]
  quizzes          Quiz[]
  quizResults      QuizResult[]
  conceptMaps      ConceptMap[]
  debateSessions   DebateSession[]
  teachSessions    TeachSession[]
  researchPapers   ResearchPaper[]
  textbookChapters TextbookChapter[]
  socraticSessions SocraticSession[]
  studySessions    StudySession[]
  quizTemplates    QuizTemplate[]
}

model SkillDependency {
  prerequisiteId String
  dependentId    String

  prerequisite SkillNode @relation("Prerequisite", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  dependent    SkillNode @relation("Dependent",    fields: [dependentId],    references: [id], onDelete: Cascade)

  @@id([prerequisiteId, dependentId])
}

model Topic {
  id          String  @id @default(uuid())
  courseId    String
  skillNodeId String?
  title       String
  week        Int     @default(1)
  status      String  @default("pending")
  source      String?

  course    Course     @relation(fields: [courseId], references: [id])
  skillNode SkillNode? @relation(fields: [skillNodeId], references: [id])
}

model Deadline {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  type      String
  dueDate   DateTime
  completed Boolean  @default(false)
  xpValue   Int      @default(100)

  course Course @relation(fields: [courseId], references: [id])
}

model Achievement {
  id         String    @id @default(uuid())
  name       String    @unique
  condition  String
  unlockedAt DateTime?
}

model Quiz {
  id          String   @id @default(uuid())
  skillNodeId String
  topicName   String
  subject     String
  questions   Json
  quizType    String   @default("practice")   // practice | exam
  createdAt   DateTime @default(now())

  skillNode SkillNode   @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
  results   QuizResult[]
}

model QuizResult {
  id          String   @id @default(uuid())
  quizId      String
  skillNodeId String
  score       Float
  passed      Boolean
  answers     Json
  takenAt     DateTime @default(now())

  quiz      Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

// ─── AI learning feature models ───────────────────────────────────────────────

model LearningPath {
  id              String    @id @default(uuid())
  userId          String    @default("default")
  name            String
  subject         String
  goalDescription String
  topics          Json      // ordered array of skillNodeIds
  estimatedHours  Json      // { skillNodeId: hours }
  pinned          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
}

model ConceptMap {
  id          String   @id @default(uuid())
  userId      String   @default("default")
  skillNodeId String
  subject     String   @default("")
  connections Json     // array of { fromNodeId, toNodeId, explanation }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skillNode   SkillNode               @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
  validations ConceptMapValidation[]
}

model ConceptMapValidation {
  id                 String   @id @default(uuid())
  conceptMapId       String
  validConnections   Json     // { connectionKey: boolean }
  missingConnections Json     // array of suggested connections
  feedback           String
  validatedAt        DateTime @default(now())

  conceptMap ConceptMap @relation(fields: [conceptMapId], references: [id], onDelete: Cascade)
}

model DebateSession {
  id          String   @id @default(uuid())
  userId      String   @default("default")
  skillNodeId String
  position    String
  turns       Json     // array of { role, text }
  score       Float?
  verdict     String?
  createdAt   DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

model TeachSession {
  id               String   @id @default(uuid())
  userId           String   @default("default")
  skillNodeId      String
  userExplanation  String
  claudeEvaluation Json     // { clarity, completeness, misconceptions, score }
  feedback         String
  createdAt        DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

model ResearchPaper {
  id          String   @id @default(uuid())
  skillNodeId String
  title       String
  url         String
  authors     String   @default("")
  year        String   @default("")
  summary     String
  source      String   @default("other") // arxiv | scholar | other
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

model TextbookChapter {
  id          String   @id @default(uuid())
  skillNodeId String
  userLevel   Int      // 0-5
  content     String   // markdown
  generatedAt DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)

  @@unique([skillNodeId, userLevel])
}

model SocraticSession {
  id           String   @id @default(uuid())
  userId       String   @default("default")
  skillNodeId  String
  turns        Json     // array of { role, text }
  sessionScore Float?
  createdAt    DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)
}

model StudySession {
  id          String    @id @default(uuid())
  userId      String    @default("default")
  skillNodeId String?
  courseId    String?   // set when logged via QuickLog (course-level, no node)
  startTime   DateTime  @default(now())
  endTime     DateTime?
  durationMins Int      @default(0)
  source      String    @default("manual") // manual | auto | session_log
  note        String?
  rawNote     String?   // raw free-text note (from old SessionLog / AI chat)
  sourceUrl   String?
  xpEarned    Int       @default(0)

  skillNode SkillNode? @relation(fields: [skillNodeId], references: [id], onDelete: SetNull)
  course    Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
}

// ─── Cost-optimization models ─────────────────────────────────────────────────

// Fix 10: log every Claude API call for auditing + cost analysis
model APICall {
  id                       String   @id @default(uuid())
  route                    String
  model                    String
  inputTokens              Int      @default(0)
  outputTokens             Int      @default(0)
  cacheCreationInputTokens Int      @default(0)
  cacheReadInputTokens     Int      @default(0)
  responseMs               Int      @default(0)
  costUsd                  Float    @default(0)
  cacheHit                 Boolean  @default(false)   // true if served from ResponseCache (no API call)
  createdAt                DateTime @default(now())

  @@index([route])
  @@index([createdAt])
}

// Fix 7: cache deterministic Claude responses keyed by input hash
model ResponseCache {
  id        String   @id @default(uuid())
  routeName String
  inputHash String   @unique
  response  Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([routeName])
}

// Fix 5: pre-generated quiz question sets per topic (no API call at quiz time)
model QuizTemplate {
  id          String   @id @default(uuid())
  skillNodeId String
  questions   Json
  difficulty  String   @default("Intermediate") // Basic | Intermediate | Advanced
  createdAt   DateTime @default(now())

  skillNode SkillNode @relation(fields: [skillNodeId], references: [id], onDelete: Cascade)

  @@index([skillNodeId])
}

// Fix 9: per-user per-route rate limiting windows
model RateLimitLog {
  id        String   @id @default(uuid())
  userId    String   @default("default")
  routeName String
  callCount Int      @default(0)
  resetAt   DateTime

  @@unique([userId, routeName])
}

// Fix 9: app-level settings (monthly spend cap, etc.)
model AppSetting {
  id                String @id @default("singleton")
  monthlyCapUsd     Float  @default(5)
  semesterGoalHours Int    @default(100)
}

// ─── PART 1: real exam / exercise / mastery tracking + personal growth ────────

model RealExam {
  id               String   @id @default(uuid())
  userId           String   @default("default")
  skillNodeIds     Json     // array of skillNodeIds
  examName         String
  subject          String
  date             DateTime @default(now())
  performanceNotes String   @default("")
  grade            String   @default("")
  masteryImpact    Json     // { skillNodeId: masteryGain }
  createdAt        DateTime @default(now())
}

model ExerciseSet {
  id            String    @id @default(uuid())
  userId        String    @default("default")
  courseId      String?   // optional link to a course (advances course progress)
  skillNodeIds  Json      // array of skillNodeIds
  filename      String
  uploadedAt    DateTime  @default(now())
  masteryImpact Json      // { skillNodeId: masteryGain }
  pctSolved     Int?      // how much was solved (for course performance)
  analyzedAt    DateTime?

  @@index([courseId])
}

model MasteryEvent {
  id          String   @id @default(uuid())
  userId      String   @default("default")
  skillNodeId String
  eventType   String   // quiz | exam | real_exam | exercise | manual | teach | debate
  score       Float    @default(0)
  masteryGain Float    @default(0)
  timestamp   DateTime @default(now())

  @@index([skillNodeId])
  @@index([eventType])
}

model LearningAbility {
  userId             String   @id @default("default")
  neuroplasticityScore Int    @default(5)
  focusScore         Int      @default(5)
  recoveryScore      Int      @default(5)
  mentalHealthScore  Int      @default(5)
  stressLevel        Int      @default(5)
  neuroplasticityTips Json    @default("[]")
  focusTips          String   @default("")
  recoveryTips       String   @default("")
  mentalHealthTips   String   @default("")
  avoidances         String   @default("")
  lastUpdated        DateTime @updatedAt
}

model SelfImprovementGoals {
  userId          String   @id @default("default")
  books           Json     @default("[]")   // [{ title, progress, notes }]
  disciplineHabits Json    @default("[]")   // [{ name, streak }]
  healthHabits    Json     @default("[]")
  spiritualGrowth Json     @default("[]")
  lastUpdated     DateTime @updatedAt
}

model CareerPathProgress {
  userId        String   @id @default("default")
  interestAreas Json     @default("[]")   // array of career paths
  progressByArea Json    @default("{}")   // { careerPath: { masteredTopics, relevantNodes, alignment } }
  lastUpdated   DateTime @updatedAt
}

model APIUsage {
  userId          String   @id @default("default")
  creditsRemaining Float   @default(0)
  lastFetched     DateTime @default(now())
  nextRefresh     DateTime @default(now())
}

// A problem you got wrong — captured from an exercise set / exam / manually.
// Later annotate WHY you failed and mark resolved once you've redone it.
model FailedProblem {
  id          String    @id @default(uuid())
  userId      String    @default("default")
  courseId    String?
  skillNodeId String?
  source      String    @default("manual") // exercise_set | exam | manual
  sourceRef   String?   // e.g. "Pset 5" or exam name
  title       String    // short label, e.g. "Problem 3 — Lagrangian duality"
  details     String?   // the problem statement / what was asked
  reason      String?   // why I failed: logic flaw, weak point, missing concept
  resolved    Boolean   @default(false) // redone successfully
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([courseId])
  @@index([skillNodeId])
  @@index([resolved])
}

// Repeatable studying-workflow activity per topic. Phases 1–4 map to the
// Studying Workflow page. A Phase-2 log with a note = a captured "Core Trick".
model PhaseLog {
  id           String   @id @default(uuid())
  userId       String   @default("default")
  skillNodeId  String
  phase        Int      // 1=Gather, 2=Proofs, 3=Homework, 4=Recall
  note         String?  // Core Trick text or reflection
  durationMins Int?     // set when logged via a study session
  source       String   @default("panel") // panel | session
  timestamp    DateTime @default(now())

  @@index([skillNodeId])
  @@index([phase])
}

// Upcoming real exams — powers the countdown + back-planned drill schedule.
model UpcomingExam {
  id           String   @id @default(uuid())
  userId       String   @default("default")
  name         String
  subject      String
  examDate     DateTime
  skillNodeIds Json     @default("[]")   // covered topics (array of skillNodeIds)
  createdAt    DateTime @default(now())

  @@index([examDate])
}
